# .env.example — provisioning placeholders. Never commit real values.
# Loaded into NVS at provisioning time (Phase 7).

# Wi-Fi (optional, if used for provisioning portal)
WIFI_SSID=<REPLACE_ME>
WIFI_PASS=<REPLACE_ME>

# LoRaWAN OTAA (Phase 5)
LORAWAN_DEVEUI=<REPLACE_ME>      # 16 hex chars
LORAWAN_JOINEUI=<REPLACE_ME>     # 16 hex chars (was AppEUI in 1.0.x)
LORAWAN_APPKEY=<REPLACE_ME>      # 32 hex chars

# RS-485 / Modbus (Phase 6). Loaded into NVS by tools/provision_nvs.py (Phase 7d).
MODBUS_DEVICE=mfm384            # mfm384 | rsfsjt  (which meter to sample)
MODBUS_BAUD=9600               # MFM384=9600, RS-FSJT-N01=4800
MODBUS_PARITY=N                # N | E | O
MODBUS_STOP=1
MODBUS_SLAVE_ID=1
SAMPLE_INTERVAL_S=60           # sample + uplink period (>=10)

# Diagnostics
LOG_LEVEL=INFO

# ── LoRaWAN server-side provisioning (ChirpStack) ─────────────────────────────
# Used by the .claude/skills/lorawan-* skills (gRPC-web). See docs/LORAWAN_PROVISIONING.md.
# Production cluster — NOT the dev copy at 10.10.8.140:8080.
CS_BASE=https://chirpstack.siot.solutions
UA=Mozilla/5.0                  # REQUIRED — Cloudflare blocks non-browser User-Agents
CS_API_TOKEN=                   # ChirpStack → Tenant 'Southern IoT' → API keys (PREFERRED). Never commit.
# dev fallback only (leave empty if using a token):
CS_ADMIN_USER=
CS_ADMIN_PASS=

# Known production IDs (non-secret defaults; the skills bake these in, override only if they change):
CS_TENANT_ID=d4f227c3-2763-459e-bc6a-61d13f1a242b          # Southern IoT
CS_APPLICATION_ID=7d5c0d50-4a4b-496d-ae7f-8ac61c4b3b18     # SouthernIoT-Devices
CS_DEVICE_PROFILE_ID=b14d1236-070b-49bb-a401-215bb29ae2b2  # OTAA-AS923

# Optional: pin a DevEUI / AppKey for provisioning (otherwise random is generated):
DEV_EUI=                        # 16 hex chars (8 bytes)
APP_KEY=                        # 32 hex chars (16 bytes)
