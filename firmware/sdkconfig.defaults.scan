# Bench profile: build the Modbus bus scanner instead of the normal LoRaWAN app.
# Usage:
#   idf.py -DSDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.defaults.scan" build flash monitor
# Scans RS-485 (CN1) unit IDs sweeping common bauds (from 9600 8N1) and logs which answer.
CONFIG_APP_MODBUS_SCAN_ON_BOOT=y
CONFIG_APP_MODBUS_SCAN_ID_LO=1
CONFIG_APP_MODBUS_SCAN_ID_HI=10
CONFIG_APP_MODBUS_SCAN_TIMEOUT_MS=300
