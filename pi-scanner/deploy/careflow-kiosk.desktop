[Desktop Entry]
Type=Application
Name=Careflow Scanner Kiosk
# Start the supervised kiosk *user* service on login (Restart=always → auto-recovers). The unit runs
# kiosk.sh; keeping the launch in the service (not here) means a crash restarts cleanly. See
# deploy/careflow-kiosk.service + deploy/README.md.
Comment=Start the supervised Careflow kiosk user service on login
Exec=systemctl --user start careflow-kiosk.service
X-GNOME-Autostart-enabled=true
