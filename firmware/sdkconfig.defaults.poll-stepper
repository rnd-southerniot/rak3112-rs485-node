# Bench overlay: poll the LEESN IG28ET stepper drive over RS-485 (CN1).
# Link settings discovered by the scan profile: 115200 8N1, unit ID 1.
# Reads FC03 holding reg 0x1015 (4117) = feedback-position LOW word (Leadshine iEM-RS map),
# once per second, for the hand-turn map-validation test: turn the shaft -> the count should
# track the turn (closed-loop drives only). Read-only & safe: this never writes a control
# register (no motion commanded). 0x1014 (4116) is the matching high word.
CONFIG_APP_MODBUS_POLL_ON_BOOT=y
CONFIG_APP_MODBUS_POLL_UNIT=1
CONFIG_APP_MODBUS_POLL_BAUD=115200
CONFIG_APP_MODBUS_POLL_FC=3
CONFIG_APP_MODBUS_POLL_REG=4117
CONFIG_APP_MODBUS_POLL_FLOAT=n
